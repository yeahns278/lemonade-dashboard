{
  "name": "lemonade-dashboard",
  "publisher": "JamesMartinez",
  "displayName": "Lemonade Dashboard",
  "description": "A management dashboard for Lemonade Server",
  "version": "0.0.7",
  "repository": {
    "type": "git",
    "url": "https://github.com/james-martinez/lemonade-dashboard.git"
  },
  "icon": "media/lemon.png",
  "engines": {
    "vscode": "^1.109.0",
    "node": ">=24.14.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lemonade.openSettings",
        "title": "Lemonade: Server Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "lemonade.openSettings",
          "when": "view == lemonadeDashboard",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Lemonade Server",
      "properties": {
        "lemonade.servers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "A friendly name for this server."
              },
              "url": {
                "type": "string",
                "description": "The full URL of your Lemonade server (e.g., http://127.0.0.1:8000)"
              },
              "apiToken": {
                "type": "string",
                "description": "API Token (LEMONADE_API_KEY) for authentication"
              }
            },
            "required": ["name", "url"]
          },
          "default": [],
          "description": "A list of Lemonade servers you want to manage."
        },
        "lemonade.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "The full URL of your Lemonade server (e.g., http://127.0.0.1:8000)",
          "deprecationMessage": "Use lemonade.servers instead."
        },
        "lemonade.apiToken": {
          "type": "string",
          "default": "",
          "description": "API Token (LEMONADE_API_KEY) for authentication",
          "deprecationMessage": "Use lemonade.servers instead."
        },
        "lemonade.defaultTab": {
          "type": "string",
          "default": "main",
          "enum": [
            "main",
            "system",
            "health",
            "library",
            "backends",
            "chat"
          ],
          "description": "The default tab to show when the dashboard opens"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lemonade-explorer",
          "title": "Lemonade",
          "icon": "media/lemon.png"
        }
      ]
    },
    "views": {
      "lemonade-explorer": [
        {
          "type": "webview",
          "id": "lemonadeDashboard",
          "name": "Manager",
          "icon": "media/lemon.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "release": "standard-version"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "sharp": "^0.34.5",
    "standard-version": "^9.5.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
